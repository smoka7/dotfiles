include-file =  ~/.config/polybar/colors
include-file =  ~/.config/polybar/modules

[bar/base]
;monitor = ${env:MONITOR:HDMI-1}
width = 100%
fixed-center = false
;override-redirect = true
;wm-restack = bspwm
;font-0 = "Hack:size=12:style=Italic;3"
font-0 = "Font Awesome 5 Free Solid:style=Solid:pixelsize=14;3"
font-1 = "Font Awesome 5 Brands Solid:style=Solid:pixelsize=14;3"
font-2 = "Iosevka:style=Regular:pixelsize=14;3"
font-3 = "icomoon:pixelsize=16;3"
padding= 1


[bar/bottom]
inherit = bar/base
pseudo-transparency = true
background =${colors.background-t}
foreground = ${colors.accent}
height = 25
line-size=0
padding = 0
modules-center = clock
modules-left =pulseaudio cnetwork i3 wifi
modules-right =  mpdbar xkeyboard
#bottom = true
font=3
;override-redirect = true
wm-restack = i3
tray-position = right
tray-background=${colors.background-t}
tray-padding = 1
tray-offset-x = 0
tray-offset-y = 0
tray-scale = 1.0
tray-maxsize = 16
[bar/overlay]
fixed-center = true
font-0 = "Font Awesome 5 Free Solid:style=Solid:pixelsize=14;3"
font-1 = "Font Awesome 5 Brands Solid:style=Solid:pixelsize=14;3"
font-2 = "Iosevka:style=Regular:pixelsize=13;3"
padding= 2
background = ${colors.background}
foreground = ${colors.white}
height = 38
width= 26%
offset-x = 70%
enable-ipc = true
border-size = 0
bottom= true
override-redirect = true

[bar/date]
offset-y = 45
inherit = bar/overlay
modules-center = time jdate
radius-bottom=5

[bar/stat]
inherit = bar/overlay
offset-y = 83
modules-left = memory temperature cpu

[bar/media]
inherit = bar/overlay
offset-y = 121
modules-left = mpd
[bar/volume]
inherit = bar/overlay
offset-y = 159
modules-right = audiobar
modules-left = backlight
modules-center = redshift
radius-top=10

[module/bspwm]
type = internal/bspwm
pin-workspaces = true
inline-mode = false
enable-click = true
enable-scroll = false
reverse-scroll = false
fuzzy-match = true
ws-icon-0 = 1;ÔČ©
ws-icon-1 = 2;Ô†ú
ws-icon-2 = 3;Ôąí
ws-icon-3 = 4;ÔÜľ
ws-icon-4 = 5;ÔČ¨
format =<label-mode> <label-state>
format-foreground = ${colors.blue}
format-margin=1
format-font=4
line-color = ${colors.red}
label-dimmed-foreground = ${colors.red}
label-dimmed-underline = ${colors.yellow}
label-mode-foreground =${colors.blue}
label-mode-padding= 1
label-focused =%icon% %index%
;label-focused =%index%
label-focused-foreground =${colors.yellow}
label-focused-background =${colors.minor}
label-focused-padding = 1
label-empty = ""
label-occupied =%icon%
;label-occupied = %index%
label-occupied-foreground=${colors.blue}
label-occupied-padding= 1
label-urgent =%icon% %index%
;label-urgent = %index%
label-urgent-background = ${colors.minor}
label-urgent-foreground = ${colors.red-m}
label-urgent-padding= 1
;label-monocle = Mono
;label-tiled = t
;label-fullscreen = full
label-floating = flo
label-pseudotiled = Pt
label-locked = L
label-sticky = S
label-private = Pr
label-marked = M
[module/xwindow]
type = internal/xwindow
label = %title:0:25:...%
label-foreground= ${colors.blue}
label-font=3
format-margin=1

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = caps lock
blacklist-2 = num lock
blacklist-1 = scroll lock
format-foreground = ${colors.accent}
format-margin = 0
format-background = ${colors.background-t}
label-layout =%layout%
label-layout-font = 3
format-padding = 1

[module/i3]
type = internal/i3
ws-icon-0 = 1;ÔČ©
ws-icon-1 = 2;ÔĄĶ
ws-icon-2 = 3;Ôąí
ws-icon-3 = 4;ÔÜľ
ws-icon-4 = 5;ÔČ¨
ws-icon-5 = 6;ÔĒ¶
format-margin=0
ws-icon-default = Ôź∂
format = <label-state><label-mode>
index-sort = true
wrapping-scroll = true
format-background = ${colors.background}
; focused = Active workspace on focused monitor
label-mode-foreground =${colors.blue}
label-mode-background =${colors.background}
label-mode-font=1
label-mode-padding= 1
label-focused =ÔĄļ
;label-focused =%index%
label-focused-foreground =${colors.amber}
label-focused-background =${colors.minor}
label-focused-font = 1
label-focused-padding = 1

label-unfocused =ÔĄĎ
;label-unfocused = %index%
label-unfocused-foreground=${colors.blue}
label-unfocused-background =${colors.minor}
label-unfocused-padding= 1
label-unfocused-font = 1
label-urgent =ÔĄĎ
;label-urgent = %index%
label-urgent-background = ${colors.minor}
label-urgent-foreground = ${colors.red-m}
label-urgent-padding= 1
label-urgent-font = 3




[module/wlan]
type = internal/network
interface = wlp9s0
interval = 2.0

format-connected = <ramp-signal><label-connected>
label-connected-padding = 1
label-connected =%{A1:networkmanager_dmenu:}%essid% ÔĄÜ %upspeed% ÔĄá %downspeed%%{A}
label-connected-foreground = ${colors.white}
label-connected-background = ${colors.teal}
ramp-signal-0 = ÔĖ≥
ramp-signal-1 = ÔĄô
ramp-signal-2 = ÔĄö
ramp-signal-3 = ÔĄė
ramp-signal-4 = ÔĖô
ramp-signal-5 = ÔĖä
ramp-signal-foreground = #d99196
ramp-signal-padding = 1
format-disconnected = <label-disconnected>
label-disconnected = "%{A1:networkmanager_dmenu:}Ôáę %{A}"






[settings]
screenchange-reload = true


