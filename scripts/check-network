#!/usr/bin/env bash

count=0

disconnected="’üŚ"
disconnected2="’£ö"
wireless_connected="’ć½"
ethernet_connected="’×¢"

ID="$(ip link | awk '/state UP/ {print $2}')"

while true; do
    if (ping -c 1 8.8.8.8|| ping -c 1 google.com) &>/dev/null; then
        if [[ $ID == e* ]]; then
            echo "$ethernet_connected" ; sleep 25
        else
            echo "$wireless_connected" ; sleep 25
        fi
    else
        echo "$disconnected" ; sleep 0.5
        echo "$disconnected2" ; sleep 0.5
    fi
done
